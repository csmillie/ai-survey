generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  passwordHash        String
  role                UserRole      @default(USER)
  lastLoginAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  disabledAt          DateTime?
  name                String?
  failedLoginAttempts Int           @default(0)
  lockedUntil         DateTime?
  auditEvents         AuditEvent[]  @relation("AuditActor")
  verifiedResponses   LlmResponse[] @relation("ResponseVerifier")
  surveysOwned        Survey[]      @relation("SurveyOwner")
  runsCreated         SurveyRun[]   @relation("RunCreator")
  shares              SurveyShare[]

  @@index([role])
}

model Survey {
  id                    String        @id @default(uuid())
  ownerId               String
  title                 String
  description           String?       @db.Text // TEXT for imported surveys; not filtered or sorted
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?
  executionMode         String        @default("standard")
  benchmarkSource       String?
  benchmarkVersion      String?
  isBenchmarkInstrument Boolean       @default(false)
  questions             Question[]
  owner                 User          @relation("SurveyOwner", fields: [ownerId], references: [id])
  runs                  SurveyRun[]
  shares                SurveyShare[]
  variables             Variable[]

  @@index([ownerId])
  @@index([deletedAt])
}

model SurveyShare {
  id        String    @id @default(uuid())
  surveyId  String
  userId    String
  role      ShareRole @default(EDIT)
  createdAt DateTime  @default(now())
  survey    Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@index([userId])
  @@index([surveyId])
}

model Variable {
  id           String   @id @default(uuid())
  surveyId     String
  key          String
  label        String?
  defaultValue String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  survey       Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, key])
  @@index([surveyId])
}

model Question {
  id                 String                 @id @default(uuid())
  surveyId           String
  order              Int
  title              String
  promptTemplate     String                 @db.Text
  mode               QuestionMode           @default(STATELESS)
  threadKey          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  configJson         Json?
  type               QuestionType           @default(OPEN_ENDED)
  code               String?
  helpText           String?                @db.Text
  constructKey       String?
  sourceSurvey       String?
  sourceVariable     String?
  benchmarkNotes     String?                @db.Text
  isBenchmarkAnchor  Boolean                @default(false)
  jobs               Job[]
  matrixRows         MatrixRow[]
  responses          LlmResponse[]
  survey             Survey                 @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questionAgreements RunQuestionAgreement[]
  questionReferees   RunQuestionReferee[]
  questionTruths     RunQuestionTruth[]

  @@index([surveyId, order])
}

model MatrixRow {
  id             String   @id @default(uuid())
  questionId     String
  rowKey         String
  label          String
  order          Int
  sourceVariable String?
  constructKey   String?
  createdAt      DateTime @default(now())
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, rowKey])
  @@index([questionId, order])
}

model ModelTarget {
  id                     String               @id @default(uuid())
  provider               Provider
  modelName              String
  isEnabled              Boolean              @default(true)
  isDefaultCostEffective Boolean              @default(false)
  inputTokenCostUsd      Decimal              @db.Decimal(12, 6)
  outputTokenCostUsd     Decimal              @db.Decimal(12, 6)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  threads                ConversationThread[]
  jobs                   Job[]
  responses              LlmResponse[]
  runModels              RunModel[]
  modelMetrics           RunModelMetric[]

  @@unique([provider, modelName])
  @@index([isEnabled])
  @@index([isDefaultCostEffective])
}

model SurveyRun {
  id                 String                 @id @default(uuid())
  surveyId           String
  createdById        String
  status             RunStatus              @default(DRAFT)
  settingsJson       Json
  limitsJson         Json
  estimatedJson      Json?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  recommendationJson Json?
  auditEvents        AuditEvent[]           @relation("AuditTargetRun")
  threads            ConversationThread[]
  jobs               Job[]
  responses          LlmResponse[]
  models             RunModel[]
  modelMetrics       RunModelMetric[]
  questionAgreements RunQuestionAgreement[]
  questionReferees   RunQuestionReferee[]
  questionTruths     RunQuestionTruth[]
  createdBy          User                   @relation("RunCreator", fields: [createdById], references: [id])
  survey             Survey                 @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId, createdAt])
  @@index([surveyId, status, completedAt])
  @@index([status])
  @@index([createdById], map: "SurveyRun_createdById_fkey")
}

model RunModel {
  id            String      @id @default(uuid())
  runId         String
  modelTargetId String
  createdAt     DateTime    @default(now())
  modelTarget   ModelTarget @relation(fields: [modelTargetId], references: [id])
  run           SurveyRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, modelTargetId])
  @@index([runId])
  @@index([modelTargetId], map: "RunModel_modelTargetId_fkey")
}

model ConversationThread {
  id            String      @id @default(uuid())
  runId         String
  modelTargetId String
  threadKey     String
  messagesJson  Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  modelTarget   ModelTarget @relation(fields: [modelTargetId], references: [id])
  run           SurveyRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, modelTargetId, threadKey])
  @@index([runId])
  @@index([modelTargetId], map: "ConversationThread_modelTargetId_fkey")
}

/// Job queue entries. Note: modelTargetId is required by the FK constraint but
/// is not semantically used by COMPUTE_METRICS or EXPORT_RUN job types — callers
/// pass any valid modelTargetId from the run to satisfy the constraint.
model Job {
  id             String      @id @default(uuid())
  runId          String
  modelTargetId  String
  questionId     String?
  threadKey      String
  type           JobType
  status         JobStatus   @default(PENDING)
  attempt        Int         @default(0)
  idempotencyKey String      @unique
  payloadJson    Json
  startedAt      DateTime?
  finishedAt     DateTime?
  lastError      String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  modelTarget    ModelTarget @relation(fields: [modelTargetId], references: [id])
  question       Question?   @relation(fields: [questionId], references: [id])
  run            SurveyRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, status])
  @@index([type, status])
  @@index([runId, type, status])
  @@index([modelTargetId], map: "Job_modelTargetId_fkey")
  @@index([questionId], map: "Job_questionId_fkey")
}

model LlmResponse {
  id                  String             @id @default(uuid())
  runId               String
  modelTargetId       String
  questionId          String
  threadKey           String
  rawText             String             @db.LongText
  parsedJson          Json?
  citationsJson       Json?
  usageJson           Json?
  costUsd             Decimal?           @db.Decimal(18, 12)
  latencyMs           Int?
  createdAt           DateTime           @default(now())
  reasoningText       String?            @db.Text
  requestMessagesJson Json?
  confidence          Float?
  normalizedScore     Float?
  selectedOptionValue String?
  matrixRowKey        String?
  verificationStatus  VerificationStatus @default(UNREVIEWED)
  verifiedAt          DateTime?
  verifiedByUserId    String?
  analysis            AnalysisResult?
  modelTarget         ModelTarget        @relation(fields: [modelTargetId], references: [id])
  question            Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  run                 SurveyRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  verifiedBy          User?              @relation("ResponseVerifier", fields: [verifiedByUserId], references: [id])

  @@unique([runId, modelTargetId, questionId, threadKey])
  @@index([runId, modelTargetId])
  @@index([runId, verificationStatus])
  @@index([modelTargetId], map: "LlmResponse_modelTargetId_fkey")
  @@index([questionId], map: "LlmResponse_questionId_fkey")
  @@index([verifiedByUserId], map: "LlmResponse_verifiedByUserId_fkey")
}

model AnalysisResult {
  id                      String      @id @default(uuid())
  responseId              String      @unique
  sentimentScore          Float?
  entitiesJson            Json?
  brandMentionsJson       Json?
  institutionMentionsJson Json?
  flagsJson               Json?
  createdAt               DateTime    @default(now())
  citationAnalysisJson    Json?
  claimsJson              Json?
  keySentencesJson        Json?
  response                LlmResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id          String     @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String
  metaJson    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  runTargetId String?
  actor       User       @relation("AuditActor", fields: [actorUserId], references: [id])
  runTarget   SurveyRun? @relation("AuditTargetRun", fields: [runTargetId], references: [id])

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
  @@index([action])
  @@index([runTargetId], map: "AuditEvent_runTargetId_fkey")
}

model RunModelMetric {
  id                   String      @id @default(uuid())
  runId                String
  modelTargetId        String
  reliabilityScore     Float
  jsonValidRate        Float
  emptyAnswerRate      Float
  shortAnswerRate      Float
  citationRate         Float
  latencyCv            Float
  costCv               Float
  penaltyBreakdownJson Json
  totalResponses       Int
  createdAt            DateTime    @default(now())
  calibrationScore     Float?
  modelTarget          ModelTarget @relation(fields: [modelTargetId], references: [id])
  run                  SurveyRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, modelTargetId])
  @@index([runId])
  @@index([modelTargetId])
}

model RunQuestionAgreement {
  id                      String    @id @default(uuid())
  runId                   String
  questionId              String
  agreementPercent        Float
  outlierModelsJson       Json
  humanReviewFlag         Boolean
  clusterDetailsJson      Json?
  createdAt               DateTime  @default(now())
  overconfidentModelsJson Json?
  factComparisonJson      Json?
  factConfidenceLevel     String?
  factConfidenceScore     Float?
  factConfidenceSignals   Json?
  question                Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  run                     SurveyRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, questionId])
  @@index([runId])
  @@index([questionId])
}

model RunQuestionTruth {
  id                       String    @id @default(uuid())
  runId                    String
  questionId               String
  truthScore               Float
  truthLabel               String
  consensusPercent         Float
  citationRate             Float
  numericDisagreementsJson Json
  claimClustersJson        Json
  breakdownJson            Json
  createdAt                DateTime  @default(now())
  question                 Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  run                      SurveyRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, questionId])
  @@index([runId])
  @@index([questionId])
}

model RunQuestionReferee {
  id                        String    @id @default(uuid())
  runId                     String
  questionId                String
  refereeModelKey           String
  summary                   String    @db.Text
  disagreementsJson         Json
  verifyChecklistJson       Json
  recommendedAnswerModelKey String?
  confidence                Float
  rawJson                   Json
  createdAt                 DateTime  @default(now())
  question                  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  run                       SurveyRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, questionId])
  @@index([runId])
  @@index([questionId])
}

enum UserRole {
  USER
  ADMIN
}

enum ShareRole {
  VIEW
  EDIT
}

enum QuestionMode {
  STATELESS
  THREADED
}

enum QuestionType {
  OPEN_ENDED
  RANKED
  SINGLE_SELECT
  BINARY
  FORCED_CHOICE
  LIKERT
  NUMERIC_SCALE
  MATRIX_LIKERT
}

enum Provider {
  OPENAI
  ANTHROPIC
  GEMINI
  XAI
  PERPLEXITY
  COPILOT
}

enum RunStatus {
  DRAFT
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  EXECUTE_QUESTION
  ANALYZE_RESPONSE
  EXPORT_RUN
  COMPUTE_METRICS
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  RETRYING
  CANCELLED
}

enum VerificationStatus {
  UNREVIEWED
  VERIFIED
  INACCURATE
}
