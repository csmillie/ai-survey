# Database (MySQL)
DATABASE_URL="mysql://root:@localhost:3306/ai_survey"

# Auth
JWT_SECRET="change-me-to-a-random-64-char-string"
SESSION_MAX_AGE_SECONDS=86400

# Admin seeding (comma-separated emails)
ADMIN_EMAILS="admin@example.com"
ADMIN_DEFAULT_PASSWORD="change-me-immediately"

# LLM Provider API Keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
XAI_API_KEY=""

# Run limits
MAX_TOKENS_PER_RUN=1000000
MAX_COST_PER_RUN_USD=50.00
MAX_CONCURRENT_RUNS_PER_USER=5

# Feature flags
ENABLE_LLM_ANALYSIS_REPASS=false

# Web server port (used by PM2 ecosystem config)
PORT=3088

# Auto-deploy webhook (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=""
WEBHOOK_PORT=9088
DEPLOY_BRANCH=main

# Beta signup notification (optional — logs to console if not set)
BETA_NOTIFY_EMAIL=
